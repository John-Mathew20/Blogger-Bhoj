<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BloggerBhoj</title>
    <link rel="stylesheet" href="/style/style.css">
  </head>
  <body>
    <h1>Blogger Bhoj</h1>
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;

    <form method="get" action="/blogs/new"><button>Create your own Blog!</button></form>
    <% for(blog of blogs){%>
      <div class="blog">
        <h2 class="title">
          <a href="/blogs/<%= blog.id%>"><%= blog.title %></a>
        </h2>
        <h4>by <%= blog.author %></h4>
        <h5><%= blog.publish_date%> </h5>
      </div>
      <hr>
    <%} %>
  </body>
</html>
